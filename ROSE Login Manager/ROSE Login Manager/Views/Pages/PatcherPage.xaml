<Page
    x:Class="ROSE_Login_Manager.Views.Pages.PatcherPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ROSE_Login_Manager.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:ROSE_Login_Manager.Models"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Patcher"
    d:DataContext="{d:DesignInstance local:PatcherPage,
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    ScrollViewer.CanContentScroll="False"
    mc:Ignorable="d">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock 
                Text="Game Client Patcher" 
                Style="{DynamicResource TitleTextBlockStyle}"
                Margin="0,0,0,8" />
            <TextBlock 
                Text="ROSE Install Directory" 
                Style="{DynamicResource BodyTextBlockStyle}"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Patcher Controls -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ui:TextBox
                Grid.Column="0"
                PlaceholderText="Enter path to game directory..."
                Text="{Binding ViewModel.GameClientPath, UpdateSourceTrigger=PropertyChanged}"
                Icon="Folder24"
                Margin="0,0,12,0" />

            <ui:Button
                Grid.Column="1"
                Command="{Binding ViewModel.BrowseClientPathCommand}"
                Content="Browse"
                Icon="FolderOpen24" />
        </Grid>

        <!-- Status and Progress -->
        <StackPanel Grid.Row="2" VerticalAlignment="Top">
            <ui:Card Margin="0,0,0,16" Padding="16">
                <Grid>
                    <ui:ProgressRing 
                        IsIndeterminate="{Binding ViewModel.IsPatching}"
                        Visibility="{Binding ViewModel.IsPatching, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Margin="0,0,0,12" />
                    <StackPanel>
                        <TextBlock 
                            Text="Current Status" 
                            Style="{DynamicResource SubtitleTextBlockStyle}"
                            FontWeight="SemiBold"
                            Margin="0,0,0,12" />

                        <ScrollViewer Height="250" VerticalScrollBarVisibility="Auto">
                            <TextBlock 
                                Text="{Binding ViewModel.StatusMessage}" 
                                Style="{DynamicResource BodyTextBlockStyle}"
                                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                Margin="0,0,0,0"
                                TextWrapping="Wrap"/>
                        </ScrollViewer>

                        <ProgressBar 
                            Value="{Binding ViewModel.PatchProgress}"
                            Maximum="100"
                            Visibility="{Binding ViewModel.IsPatching, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <StackPanel Orientation="Horizontal" Margin="0 16 0 0">
                            <ui:Button
                            Command="{Binding ViewModel.CheckForUpdatesCommand}"
                            Content="Run Patcher - Force"
                            Icon="ArrowClockwise24"
                            Appearance="Primary"
                            Margin="0,0,8,0" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </ui:Card>
        </StackPanel>

        <!-- Error Message -->
        <ui:SnackbarPresenter 
            Grid.Row="0" Grid.RowSpan="4"
            x:Name="SnackbarPresenter" />
    </Grid>
</Page>
