<Page
    x:Class="ROSE_Login_Manager.Views.Pages.PatcherPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ROSE_Login_Manager.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="clr-namespace:ROSE_Login_Manager.Models"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Patcher"
    d:DataContext="{d:DesignInstance local:PatcherPage, IsDesignTimeCreatable=False}"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    ScrollViewer.CanContentScroll="False"
    mc:Ignorable="d" 
    d:DesignHeight="600" d:DesignWidth="1000">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <StackPanel Grid.Row="0">
            <TextBlock 
                Text="Game Client Patcher" 
                Style="{DynamicResource TitleTextBlockStyle}"
                Margin="0 0 0 16" />
        </StackPanel>

        <!-- Directory Selection Section -->
        <StackPanel Grid.Row="1" Margin="0 0 0 16">
            <TextBlock 
                Text="ROSE Install Directory" 
                Style="{DynamicResource SubtitleTextBlockStyle}"
                FontWeight="SemiBold" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:TextBox
                    Grid.Column="0"
                    PlaceholderText="Enter path to game directory..."
                    Text="{Binding ViewModel.GameClientPath, UpdateSourceTrigger=PropertyChanged}"
                    Margin="0,0,12,0" />

                <ui:Button
                    Grid.Column="1"
                    Command="{Binding ViewModel.BrowseClientPathCommand}"
                    Content="Browse" />
            </Grid>
        </StackPanel>

        <!-- Main Content Section -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <ui:Card Grid.Column="0"
                     Padding="4"
                     VerticalAlignment="Stretch" 
                     VerticalContentAlignment="Stretch">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                        Text="Current Status" 
                        Style="{DynamicResource SubtitleTextBlockStyle}"
                        FontWeight="SemiBold"
                        Margin="4"/>

                    <!-- Patcher Log Content Area -->
                    <ScrollViewer Grid.Row="1"
                        VerticalScrollBarVisibility="Auto"
                        VerticalAlignment="Stretch"
                        Margin="8 4 4 4">
                        <TextBlock 
                            Text="{Binding ViewModel.StatusMessage}"
                            Style="{DynamicResource BodyTextBlockStyle}"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap"/>
                    </ScrollViewer>

                    <!-- Progress Ring Overlay -->
                    <ui:ProgressRing Grid.Row="1"
                        IsIndeterminate="{Binding ViewModel.IsPatching}"
                        Visibility="{Binding ViewModel.IsPatching, Converter={StaticResource BooleanToVisibilityConverter}}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />

                    <ui:Button Grid.Row="2"
                        Command="{Binding ViewModel.CheckForUpdatesCommand}"
                        Content="Run Patcher"
                        Icon="ArrowClockwise24"
                        Appearance="Primary"
                        HorizontalAlignment="Left"
                        Margin="4" />
                </Grid>
            </ui:Card>

            <ui:Card Grid.Column="2" 
                     Padding="4"
                     VerticalAlignment="Stretch" 
                     VerticalContentAlignment="Stretch">
                <StackPanel>
                    <TextBlock 
                        Text="Patch Notes" 
                        Style="{DynamicResource SubtitleTextBlockStyle}"
                        FontWeight="SemiBold"
                        Margin="4" />

                    <ScrollViewer 
                        Height="250" 
                        VerticalScrollBarVisibility="Auto">
                        <TextBlock 
                            Margin="8 4 4 4"
                            Text="No patch notes available" 
                            Style="{DynamicResource BodyTextBlockStyle}"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap"/>
                    </ScrollViewer>
                </StackPanel>
            </ui:Card>

        </Grid>
    </Grid>
</Page>
